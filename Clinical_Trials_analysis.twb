      <column caption='Enrollment_bracket' datatype='string' name='[Calculation_0813662469660673]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([enrollment_count]) THEN&#13;&#10;    &quot;Unknown&quot;&#13;&#10;&#13;&#10;ELSEIF [enrollment_count] &lt; 50 THEN&#13;&#10;    &quot;&lt;50&quot;&#13;&#10;&#13;&#10;ELSEIF [enrollment_count] &lt; 200 THEN&#13;&#10;    &quot;50-199&quot;&#13;&#10;&#13;&#10;ELSEIF [enrollment_count] &lt; 500 THEN&#13;&#10;    &quot;200-499&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;500+&quot;&#13;&#10;END' />
